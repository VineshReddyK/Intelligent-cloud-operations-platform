{
  "title": "ICOP Platform Overview",
  "uid": "icop-overview",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_used_bytes, service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{service=~\"$service\"}[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP Error Rate (5xx)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{service=~\"$service\",outcome=\"SERVER_ERROR\"}[1m]))",
          "legendFormat": "errors/s"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Circuit Breaker State",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{name=\"payment-processor\"}",
          "legendFormat": "{{state}}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "HALF_OPEN", "color": "yellow" } } }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "JVM Heap Used",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\", service=~\"$service\"}) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate by Service",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{service=~\"$service\"}[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "P99 HTTP Latency by Service",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{service=~\"$service\"}[1m])) by (le, service))",
          "legendFormat": "{{service}} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap Memory by Service",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\", service=~\"$service\"}) by (service)",
          "legendFormat": "{{service}} used"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\", service=~\"$service\"}) by (service)",
          "legendFormat": "{{service}} max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kafka_consumer_fetch_manager_records_lag{service=~\"$service\"}) by (service, topic)",
          "legendFormat": "{{service}} / {{topic}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Circuit Breaker Calls (payment-processor)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(resilience4j_circuitbreaker_calls_total{name=\"payment-processor\"}[1m])",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "JVM GC Pause Time",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_sum{service=~\"$service\"}[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
